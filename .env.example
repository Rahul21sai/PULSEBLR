# PulseBLR — Environment Variables

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pulseblr?retryWrites=true&w=majority

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# In production, set to your deployment URL (e.g. https://pulseblr.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# ── NVIDIA NIM — AI event tagging (PRIMARY LLM) ───────────────────────────────
# Get your free API key at https://build.nvidia.com → sign in → top-right "Get API Key"
NVIDIA_API_KEY=nvapi-...
# Model to use (default: meta/llama-3.1-8b-instruct). Other good options:
#   mistralai/mixtral-8x7b-instruct
#   meta/llama-3.1-70b-instruct
#   nvidia/nemotron-4-340b-instruct
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# Leave blank to use the default NVIDIA NIM cloud endpoint
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Anthropic Claude — AI event tagging (FALLBACK if NVIDIA key not set) ───────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Email digest (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
