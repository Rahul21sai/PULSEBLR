# PulseBLR — Environment Variables

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pulseblr?retryWrites=true&w=majority

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# In production, set to your deployment URL (e.g. https://pulseblr.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# ── Optional: AI-powered scraping (Anthropic) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Email digest (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
