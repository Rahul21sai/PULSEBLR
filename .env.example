# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/pulseblr
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pulseblr?retryWrites=true&w=majority

# Application
NODE_ENV=development

# LLM API for auto-tagging (Phase 3)
ANTHROPIC_API_KEY=your_api_key_here

# Email notifications (Phase 4)
RESEND_API_KEY=your_api_key_here
USER_EMAIL=your_email@example.com

# Future: Web Push notifications (Phase 4)
# VAPID_PUBLIC_KEY=your_public_key
# VAPID_PRIVATE_KEY=your_private_key

